keybind = performable:shift+end=adjust_selection:end_of_line
keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
keybind = global:alt+p=toggle_quick_terminal
keybind = ctrl+tab=text:\x1b[27;5;9~
keybind = ctrl+shift+tab=text:\x1b[27;6;9~

# CTl O/I
keybind = "alt+left=text:\x0fzz"
keybind = "alt+right=text:\x0ezz"
